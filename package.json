{
  "name": "infdb-leak-fixer",
  "version": "1.0.0",
  "private": true,
  "description": "Tool to detect and fix leaked secrets (GitLab tokens) in Git repositories",
  "main": "dist/fix-leak.js",
  "scripts": {
    "build": "tsc",
    "test": "jest --passWithNoTests",
    "start": "node dist/fix-leak.js",
    "clean": "rm -rf dist",
    "prebuild": "npm run clean"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.11.19",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "typescript": "^5.3.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "roots": [
      "<rootDir>/tools"
    ],
    "testMatch": [
      "**/?(*.)+(spec|test).ts"
    ]
  },
  "files": [
    "dist/",
    "tools/"
  ],
  "license": "UNLICENSED"
}